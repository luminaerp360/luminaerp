{
  "name": "lumina-erp",
  "version": "1.0.0",
  "private": true,
  "description": "Lumina ERP - Enterprise Resource Planning Monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "dev:backend": "pnpm --filter @lumina/backend dev",
    "dev:frontend": "pnpm --filter @lumina/frontend dev",
    "dev:admin": "pnpm --filter @lumina/admin dev",
    "build": "turbo run build",
    "build:backend": "pnpm --filter @lumina/backend build",
    "build:frontend": "pnpm --filter @lumina/frontend build",
    "build:admin": "pnpm --filter @lumina/admin build",
    "start": "turbo run start",
    "start:backend": "pnpm --filter @lumina/backend start",
    "start:frontend": "pnpm --filter @lumina/frontend start",
    "start:admin": "pnpm --filter @lumina/admin start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:frontend": "cd apps/frontend && rm -rf .angular dist node_modules",
    "clean:admin": "cd apps/admin && rm -rf .angular dist node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "docker:up": "pnpm --filter @lumina/backend docker:up",
    "docker:down": "pnpm --filter @lumina/backend docker:down",
    "prisma:generate": "pnpm --filter @lumina/backend prisma generate",
    "prisma:deploy": "pnpm --filter @lumina/backend prisma:dev:deploy"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "prisma": "^5.22.0",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
