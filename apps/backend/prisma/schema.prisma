generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscription {
  id              Int                @id @default(autoincrement())
  organizationId  Int                @unique
  plan            SubscriptionPlan   @default(BASIC)
  status          SubscriptionStatus @default(TRIAL)
  startDate       DateTime
  endDate         DateTime
  maxDevices      Int                @default(1)
  maxUsers        Int                @default(2)
  maxLocations    Int                @default(1)
  licenseKey      String             @unique
  lastBillingDate DateTime?
  price           Float
  autoRenew       Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  devices         Device[]
  organization    Organization       @relation(fields: [organizationId], references: [id])

  @@map("subscriptions")
}

model Device {
  id             Int          @id @default(autoincrement())
  subscriptionId Int
  deviceId       String       @unique
  deviceName     String
  lastActive     DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("devices")
}

model OfflineSubscription {
  id                  Int                @id @default(autoincrement())
  organizationName    String
  organizationAddress String?
  organizationContact String?
  plan                SubscriptionPlan   @default(BASIC)
  status              SubscriptionStatus @default(ACTIVE)
  licenseKey          String             @unique
  startDate           DateTime
  endDate             DateTime
  durationDays        Int
  maxDevices          Int                @default(1)
  maxUsers            Int                @default(2)
  maxLocations        Int                @default(1)
  initialCheckpoint   String
  remarks             String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  createdBy           String?
  lastValidatedAt     DateTime?
  devices             OfflineDevice[]

  @@map("offline_subscriptions")
}

model OfflineDevice {
  id                    Int                 @id @default(autoincrement())
  offlineSubscriptionId Int
  deviceId              String
  deviceName            String?
  firstRegistered       DateTime            @default(now())
  lastActive            DateTime?
  isActive              Boolean             @default(true)
  validationCount       Int                 @default(0)
  offlineSubscription   OfflineSubscription @relation(fields: [offlineSubscriptionId], references: [id], onDelete: Cascade)

  @@unique([offlineSubscriptionId, deviceId])
  @@map("offline_devices")
}

model Organization {
  id                        Int                        @id @default(autoincrement())
  name                      String
  address                   String?
  contact                   String?
  complementaryMessage      String?
  stations                  Json?
  bankDetails               Json?
  mpesaDetails              Json?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  logoUrl                   String?                    @default("")
  billPayments              BillPayment[]
  bills                     Bill[]
  blogs                     Blog[]
  careers                   Careers[]
  categories                Category[]
  chartOfAccounts           ChartOfAccount[]
  clientPayment             ClientPayment[]
  commissionPayments        CommissionPayment[]
  commissionRecords         CommissionRecord[]
  creditSalesPayments       CreditSalePayment[]
  creditSales               CreditSale[]
  customers                 Customer[]
  departments               Department[]
  storeCategories           StoreCategory[]
  storeProducts             StoreProduct[]
  storePurchases            StorePurchase[]
  requisitions              Requisition[]
  documentCounters          DocumentCounter[]
  expenses                  Expense[]
  inventories               Inventory[]
  batches                   InventoryBatch[]
  movements                 InventoryMovement[]
  inventoryValuations       InventoryValuation[]
  invoices                  Invoice[]
  localPurchaseOrders       LocalPurchaseOrder[]
  locations                 Location[]
  mpesaTransactions         MpesaTransaction[]
  news                      News[]
  notifications             Notification[]
  orders                    Order[]
  settings                  OrganizationSettings?
  paymentTransactions       PaymentTransaction[]
  printingJob               PrintingJob[]
  products                  Product[]
  qualityInspections        QualityInspection[]
  quotations                Quotation[]
  receivablePayments        ReceivablePayment[]
  receivables               Receivable[]
  recurringInvoiceTemplates RecurringInvoiceTemplate[]
  reorderRules              ReorderRule[]
  serialNumbers             SerialNumber[]
  stockAdjustments          StockAdjustment[]
  stockTakes                StockTake[]
  stockReservations         StockReservation[]
  transfersFrom             StockTransfer[]            @relation("TransfersFrom")
  transfersTo               StockTransfer[]            @relation("TransfersTo")
  subscription              Subscription?
  suppliers                 Supplier[]
  systemLogs                SystemLog[]
  teams                     Team[]
  tenders                   Tenders[]
  tickets                   Ticket[]
  userProductCommissions    UserProductCommission[]
  users                     User[]
  warehouseLocations        WarehouseLocation[]
  productAttributes         ProductAttribute[]
  productTags               ProductTag[]
  unitOfMeasures            UnitOfMeasure[]
  priceTiers                PriceTier[]
  productUnits              ProductUnit[]
  productAssets             ProductAsset[]
  orderSoldUnits            OrderSoldUnit[]
  taxRates                  TaxRate[]
  walletTransactions        CustomerWalletTransaction[]

  @@map("organizations")
}

model Location {
  id                 Int                 @id @default(autoincrement())
  name               String
  address            String?
  contact            String?
  organizationId     Int
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventories        Inventory[]
  organization       Organization        @relation(fields: [organizationId], references: [id])
  orders             Order[]
  products           Product[]
  transfersFrom      StockTransfer[]     @relation("TransfersFromLocation")
  transfersTo        StockTransfer[]     @relation("TransfersToLocation")
  users              User[]
  warehouseLocations WarehouseLocation[]

  @@map("locations")
}

model User {
  id                            Int                        @id @default(autoincrement())
  organizationId                Int
  locationId                    Int?
  email                         String                     @unique
  password                      String
  fullName                      String
  username                      String
  phone                         String                     @default("")
  status                        String                     @default("Active")
  role                          String                     @default("Admin")
  createdBy                     String                     @default("")
  photoURL                      String                     @default("https://res.cloudinary.com/dfsd8beyu/image/upload/v1720257318/defaultUser_f7bvpx.webp")
  permissions                   Json                       @default("{}")
  googleId                      String?                    @unique
  googleEmail                   String?
  authProvider                  String                     @default("email")
  isEmailVerified               Boolean                    @default(false)
  emailVerifiedAt               DateTime?
  createdAt                     DateTime                   @default(now())
  updatedAt                     DateTime                   @updatedAt
  Blog                          Blog[]
  Careers                       Careers[]
  commissionPayments            CommissionPayment[]
  commissionRecords             CommissionRecord[]
  salesPersonInvoices           Invoice[]                  @relation("SalesPersonInvoices")
  News                          News[]
  notifications                 Notification[]
  salesPersonOrders             Order[]                    @relation("SalesPersonOrders")
  Order                         Order[]
  salesPersonRecurringTemplates RecurringInvoiceTemplate[] @relation("SalesPersonRecurringTemplates")
  systemLogs                    SystemLog[]
  Tenders                       Tenders[]
  tickets                       Ticket[]
  userProductCommissions        UserProductCommission[]
  approvedPurchases             StorePurchase[]            @relation("PurchaseApprover")
  createdPurchases              StorePurchase[]            @relation("PurchaseCreator")
  rejectedPurchases             StorePurchase[]            @relation("PurchaseRejector")
  receivedPurchases             StorePurchaseReceive[]     @relation("PurchaseReceiver")
  approvedRequisitions          Requisition[]              @relation("RequisitionApprover")
  rejectedRequisitions          Requisition[]              @relation("RequisitionRejector")
  issuedRequisitions            Requisition[]              @relation("RequisitionIssuer")
  requestedRequisitions         Requisition[]              @relation("RequisitionRequester")
  productStatusChanges          ProductStatusHistory[]
  productAssets                 ProductAsset[]
  location                      Location?                  @relation(fields: [locationId], references: [id])
  organization                  Organization               @relation(fields: [organizationId], references: [id])

  @@map("users")
}

model UserOrganizationAccess {
  id             Int       @id @default(autoincrement())
  userId         Int
  organizationId Int
  role           String    @default("User")
  permissions    Json      @default("{}")
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastAccessedAt DateTime?

  @@unique([userId, organizationId])
  @@map("user_organization_access")
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
  @@map("email_verification_tokens")
}

model Product {
  id                     Int                     @id @default(autoincrement())
  organizationId         Int
  locationId             Int?
  name                   String
  description            String?
  pictureUrl             String?
  productIdNumber        String
  reorderLevel           Int?
  availability           Boolean?                @default(true)
  quantity               Int?
  storeQuantity          Int?
  countable              Boolean?                @default(true)
  isService              Boolean?                @default(false)
  price                  Float?                  @default(0)
  expiryDate             DateTime?
  categoryId             Int
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  buyingPrice            Float?                  @default(0)
  wholesalePrice         Float?                  @default(0)
  defaultCommissionType  String?                 @default("PERCENTAGE")
  defaultCommissionValue Float?                  @default(0)
  isCommissionable       Boolean                 @default(true)
  // New modern product features
  status                 ProductStatus           @default(ACTIVE)
  statusReason           String?
  discontinuedAt         DateTime?
  archivedAt             DateTime?
  taxRateId              Int?
  isTaxable              Boolean                 @default(true)
  taxInclusive           Boolean                 @default(false)
  minOrderQuantity       Int?
  maxOrderQuantity       Int?
  tags                   String[]                @default([])
  sku                    String?
  weight                 Float?
  weightUnit             String?                 @default("kg")
  dimensions             Json? // {length, width, height, unit}
  hasVariants            Boolean                 @default(false)
  trackingMode           ProductTrackingMode     @default(NONE)
  requiresUniqueIdentifiers Boolean              @default(false)
  requiredAssetTypes     ProductAssetType[]      @default([])
  batchTracking          Boolean                 @default(false)
  // Relations
  commissionRecords      CommissionRecord[]
  batches                InventoryBatch[]
  movements              InventoryMovement[]
  valuations             InventoryValuation[]
  category               Category                @relation(fields: [categoryId], references: [id])
  location               Location?               @relation(fields: [locationId], references: [id])
  organization           Organization            @relation(fields: [organizationId], references: [id])
  reorderRules           ReorderRule[]
  serialNumbers          SerialNumber[]
  productUnits           ProductUnit[]
  assets                 ProductAsset[]
  soldUnits              OrderSoldUnit[]
  reservations           StockReservation[]
  userCommissionRates    UserProductCommission[]
  // New relations
  taxRate                TaxRate?                @relation(fields: [taxRateId], references: [id])
  variants               ProductVariant[]
  images                 ProductImage[]
  tagMappings            ProductTagMapping[]
  pricing                ProductPricing[]
  uoms                   ProductUOM[]
  suppliers              ProductSupplier[]
  bundles                ProductBundle[]
  bundleComponents       BundleComponent[]
  statusHistory          ProductStatusHistory[]
  stockTakeItems         StockTakeItem[]

  @@unique([organizationId, productIdNumber])
  @@unique([organizationId, name])
  @@index([status])
  @@index([organizationId, status])
  @@map("products")
}

model Category {
  id             Int          @id @default(autoincrement())
  organizationId Int
  name           String
  description    String
  pictureUrl     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  Product        Product[]

  @@unique([organizationId, name])
  @@map("categories")
}

model Order {
  id                 Int                @id @default(autoincrement())
  organizationId     Int
  locationId         Int?
  items              Json
  total              Float
  cashPaid           Float
  mpesaPaid          Float
  bankPaid           Float
  totalAmountPaid    Float
  taxAmount          Float
  discountAmount     Float
  customerId         Int                @default(0)
  customer_name      String             @default("")
  printerIp          String
  isVoided           Boolean
  voidedBy           Int                @default(0)
  userId             Int
  created_by         String             @default("")
  mpesaTransactionId String             @default("")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  customerEmail      String             @default("")
  receiptNumber      String?
  salesPersonId      Int?
  commissionRecords  CommissionRecord[]
  MpesaTransaction   MpesaTransaction[]
  payments           OrderPayment[]
  directSoldUnits    ProductUnit[]      @relation("DirectUnitOrder")
  soldUnits          OrderSoldUnit[]
  location           Location?          @relation(fields: [locationId], references: [id])
  organization       Organization       @relation(fields: [organizationId], references: [id])
  salesPerson        User?              @relation("SalesPersonOrders", fields: [salesPersonId], references: [id])
  user               User               @relation(fields: [userId], references: [id])
  Refund             Refund[]

  @@index([organizationId, receiptNumber])
  @@map("orders")
}

model OrderPayment {
  id                Int                  @id @default(autoincrement())
  orderId           Int
  organizationId    Int
  paymentMethodId   Int?
  paymentMethodCode String
  paymentMethodName String
  amount            Float
  transactionCode   String?
  paymentDate       DateTime             @default(now())
  notes             String?
  recordedBy        String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  order             Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod     PaymentMethodConfig? @relation(fields: [paymentMethodId], references: [id])

  @@index([orderId])
  @@index([paymentMethodId])
  @@index([paymentDate])
  @@map("order_payments")
}

model Blog {
  id             Int          @id @default(autoincrement())
  organizationId Int
  title          String
  body           String
  pictureUrl     String?
  slug           String?
  userId         Int
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@map("blogs")
}

model News {
  id             Int          @id @default(autoincrement())
  organizationId Int
  title          String
  body           String
  pictureUrl     String?
  slug           String?
  userId         Int
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@map("news")
}

model Team {
  id             Int          @id @default(autoincrement())
  organizationId Int
  fullName       String
  position       String
  email          String
  phone          String
  is_active      Boolean
  pictureUrl     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@map("team")
}

model Tenders {
  id                 Int          @id @default(autoincrement())
  organizationId     Int
  title              String
  slug               String?
  description        String
  aplicationDateLine String
  is_open            Boolean
  fileUrl            String?
  pictureUrl         String?
  userId             Int
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id])
  user               User         @relation(fields: [userId], references: [id])

  @@map("tenders")
}

model Careers {
  id                 Int          @id @default(autoincrement())
  organizationId     Int
  title              String
  slug               String?
  description        String
  requirements       String
  aplicationDateLine String
  is_open            Boolean
  fileUrl            String?
  pictureUrl         String?
  userId             Int
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id])
  user               User         @relation(fields: [userId], references: [id])

  @@map("careers")
}

model MpesaTransaction {
  id                 Int           @id @default(autoincrement())
  organizationId     Int?
  merchantRequestID  String
  checkoutRequestID  String
  resultCode         Int
  resultDesc         String
  amount             Float?
  mpesaReceiptNumber String?
  transactionDate    DateTime?
  phoneNumber        String?
  orderId            Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  order              Order?        @relation(fields: [orderId], references: [id])
  organization       Organization? @relation(fields: [organizationId], references: [id])

  @@map("mpesa_transactions")
}

model Quotation {
  id              Int          @id @default(autoincrement())
  organizationId  Int
  referenceNumber String
  customerId      Int?
  items           Json
  totalAmount     Float
  status          String
  created_by      String       @default("")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  sendEmail       Boolean      @default(false)
  totalTax        Float        @default(0)
  organization    Organization @relation(fields: [organizationId], references: [id])
  customer        Customer?    @relation(fields: [customerId], references: [id])

  @@unique([organizationId, referenceNumber])
  @@map("quotations")
}

model LocalPurchaseOrder {
  id                  Int          @id @default(autoincrement())
  organizationId      Int
  referenceNumber     String
  supplierId          Int
  items               Json
  totalAmount         Float
  subtotal            Float        @default(0)
  taxAmount           Float        @default(0)
  discountAmount      Float        @default(0)
  shippingCost        Float        @default(0)
  deliveryDate        DateTime?
  paymentTerms        String?
  shippingAddress     String?
  notes               String?
  priority            String       @default("MEDIUM")
  created_by          String       @default("")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  isApproved          Boolean      @default(false)
  approvedBy          Int?
  approvedAt          DateTime?
  approvalNotes       String?
  isPurchaseConverted Boolean      @default(false)
  purchaseConvertedBy Int?
  purchaseConvertedAt DateTime?
  purchaseReference   String?
  isRejected          Boolean      @default(false)
  rejectedBy          Int?
  rejectedAt          DateTime?
  rejectionReason     String?
  status              LpoStatus    @default(PENDING)
  organization        Organization @relation(fields: [organizationId], references: [id])
  supplier            Supplier     @relation(fields: [supplierId], references: [id])

  @@unique([organizationId, referenceNumber])
  @@index([status])
  @@index([isApproved])
  @@index([isPurchaseConverted])
  @@map("local_purchase_orders")
}

model Supplier {
  id                   Int                  @id @default(autoincrement())
  organizationId       Int
  name                 String
  phone                String
  totalUnpaidSuppliers Int
  deleted              Boolean
  bills                Bill[]
  Inventory            Inventory[]
  inventoryBatches     InventoryBatch[]
  LocalPurchaseOrder   LocalPurchaseOrder[]
  reorderRules         ReorderRule[]
  storePurchases       StorePurchase[]
  productSuppliers     ProductSupplier[]
  organization         Organization         @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, phone])
  @@map("suppliers")
}

model Customer {
  id                        Int                        @id @default(autoincrement())
  organizationId            Int
  fullName                  String
  phoneNumber               String
  dueCredit                 Float?
  walletBalance             Float                      @default(0)
  isActive                  Boolean?
  customerType              CustomerType               @default(INDIVIDUAL)
  kraPin                    String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  email                     String                     @default("")
  organization              Organization               @relation(fields: [organizationId], references: [id])
  invoices                  Invoice[]
  quotations                Quotation[]
  receivables               Receivable[]
  recurringInvoiceTemplates RecurringInvoiceTemplate[]
  serialNumbers             SerialNumber[]
  walletTransactions        CustomerWalletTransaction[]

  @@unique([organizationId, phoneNumber])
  @@map("customers")
}

model Invoice {
  id                  Int                       @id @default(autoincrement())
  organizationId      Int
  invoiceNumber       String
  invoiceType         InvoiceType               @default(CREDIT_SALE)
  referenceNumber     String?
  customerId          Int
  customerName        String
  customerPhone       String?
  customerEmail       String?
  customerAddress     String?
  customerTaxId       String?
  issueDate           DateTime                  @default(now())
  dueDate             DateTime
  orderDate           DateTime?
  subtotal            Float
  taxAmount           Float                     @default(0)
  discountAmount      Float                     @default(0)
  totalAmount         Float
  amountPaid          Float                     @default(0)
  balanceDue          Float
  paymentTerms        String                    @default("Net 30")
  paymentTermsDays    Int                       @default(30)
  lateFeePercentage   Float                     @default(0)
  lateFeeAmount       Float                     @default(0)
  status              InvoiceStatus             @default(DRAFT)
  fullyPaid           Boolean                   @default(false)
  sentAt              DateTime?
  viewedAt            DateTime?
  paidAt              DateTime?
  taxRate             Float                     @default(0)
  taxType             String?
  organizationTaxId   String?
  notes               String?
  termsAndConditions  String?
  footerText          String?
  createdBy           String
  shiftId             Int?
  publicToken         String?                   @unique
  qrCodeData          String?
  emailSent           Boolean                   @default(false)
  emailSentAt         DateTime?
  emailOpenedAt       DateTime?
  oldCreditSaleId     Int?                      @unique
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  recurringTemplateId Int?
  salesPersonId       Int?
  orderId             Int?
  commissionRecords   CommissionRecord[]
  items               InvoiceItem[]
  payments            InvoicePayment[]
  customer            Customer                  @relation(fields: [customerId], references: [id])
  organization        Organization              @relation(fields: [organizationId], references: [id])
  recurringTemplate   RecurringInvoiceTemplate? @relation("RecurringInvoices", fields: [recurringTemplateId], references: [id])
  salesPerson         User?                     @relation("SalesPersonInvoices", fields: [salesPersonId], references: [id])

  @@unique([organizationId, invoiceNumber])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([recurringTemplateId])
  @@map("invoices")
}

model InvoiceItem {
  id                 Int      @id @default(autoincrement())
  invoiceId          Int
  productId          Int?
  productName        String
  description        String?
  sku                String?
  quantity           Float
  unitPrice          Float
  subtotal           Float
  taxRate            Float    @default(0)
  taxAmount          Float    @default(0)
  discountPercentage Float    @default(0)
  discountAmount     Float    @default(0)
  totalAmount        Float
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  invoice            Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model InvoicePayment {
  id                  Int                  @id @default(autoincrement())
  invoiceId           Int
  organizationId      Int
  amount              Float
  paymentMethod       PaymentMethod
  transactionCode     String?
  paymentDate         DateTime             @default(now())
  notes               String?
  recordedBy          String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  paymentMethodCode   String?
  paymentMethodId     Int?
  paymentMethodName   String?
  invoice             Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentMethodConfig PaymentMethodConfig? @relation(fields: [paymentMethodId], references: [id])

  @@index([invoiceId])
  @@index([paymentMethodId])
  @@index([paymentDate])
  @@map("invoice_payments")
}

model RecurringInvoiceTemplate {
  id                     Int                    @id @default(autoincrement())
  organizationId         Int
  templateName           String
  templateCode           String                 @unique
  customerId             Int
  frequency              RecurrenceFrequency
  intervalCount          Int                    @default(1)
  startDate              DateTime
  endDate                DateTime?
  nextInvoiceDate        DateTime
  dayOfMonth             Int?
  dayOfWeek              Int?
  paymentTermsDays       Int                    @default(30)
  taxRate                Float                  @default(0)
  discountAmount         Float                  @default(0)
  notes                  String?
  termsAndConditions     String?
  footerText             String?
  status                 RecurringStatus        @default(ACTIVE)
  totalGenerated         Int                    @default(0)
  lastGeneratedDate      DateTime?
  lastGeneratedInvoiceId Int?
  autoSendEmail          Boolean                @default(true)
  emailRecipients        String?
  createdBy              String
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  salesPersonId          Int?
  generatedInvoices      Invoice[]              @relation("RecurringInvoices")
  items                  RecurringInvoiceItem[]
  customer               Customer               @relation(fields: [customerId], references: [id])
  organization           Organization           @relation(fields: [organizationId], references: [id])
  salesPerson            User?                  @relation("SalesPersonRecurringTemplates", fields: [salesPersonId], references: [id])

  @@index([organizationId, status, nextInvoiceDate])
  @@index([customerId])
  @@map("recurring_invoice_templates")
}

model RecurringInvoiceItem {
  id             Int                      @id @default(autoincrement())
  templateId     Int
  productId      Int?
  productName    String
  description    String?
  quantity       Float
  unitPrice      Float
  taxRate        Float                    @default(0)
  discountAmount Float                    @default(0)
  sortOrder      Int                      @default(0)
  template       RecurringInvoiceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("recurring_invoice_items")
}

model CreditSale {
  id                      Int                 @id @default(autoincrement())
  organizationId          Int
  customer_id             Int
  order_id                Int?
  items                   Json                @default("[]")
  credit_amount           Float
  order_date              DateTime?
  payment_date            DateTime?
  amount_paid             Float?
  fully_paid              Float?
  customer_name           String
  created_by              String
