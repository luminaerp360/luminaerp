  @@map("payment_methods")
}

model DocumentCounter {
  id              Int          @id @default(autoincrement())
  organizationId  Int
  documentType    String
  year            Int          @default(0)
  month           Int          @default(0)
  currentValue    Int          @default(0)
  lastIncremented DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, documentType, year, month])
  @@index([organizationId, documentType])
  @@map("document_counters")
}

model UserProductCommission {
  id              Int          @id @default(autoincrement())
  organizationId  Int
  userId          Int
  productId       Int
  commissionType  String
  commissionValue Float
  createdBy       String       @default("")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([organizationId, userId])
  @@index([organizationId, productId])
  @@map("user_product_commissions")
}

model CommissionRecord {
  id               Int          @id @default(autoincrement())
  organizationId   Int
  userId           Int
  sourceType       String
  sourceId         Int
  orderId          Int?
  invoiceId        Int?
  productId        Int
  productName      String
  quantitySold     Float
  unitPrice        Float
  totalSaleAmount  Float
  commissionType   String
  commissionRate   Float
  commissionAmount Float
  status           String       @default("PENDING")
  paidAt           DateTime?
  paidBy           String?
  paymentReference String?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  invoice          Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  order            Order?       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([organizationId, status])
  @@index([sourceType, sourceId])
  @@index([userId, status])
  @@map("commission_records")
}

model CommissionPayment {
  id                Int                           @id @default(autoincrement())
  organizationId    Int
  batchNumber       String
  userId            Int
  totalAmount       Float
  paymentMethod     String                        @default("MULTIPLE") // Can be single method or "MULTIPLE"
  paymentDate       DateTime
  commissionIds     Json
  paidBy            String
  notes             String?
  startDate         DateTime? // For period-based payments
  endDate           DateTime? // For period-based payments
  paymentType       String                        @default("MANUAL") // MANUAL, BULK_PERIOD, BULK_ALL_UNPAID
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  organization      Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentBreakdown  CommissionPaymentBreakdown[]

  @@index([organizationId, userId])
  @@index([batchNumber])
  @@index([paymentDate])
  @@map("commission_payments")
}

model CommissionPaymentBreakdown {
  id                  Int                 @id @default(autoincrement())
  commissionPaymentId Int
  paymentMethodId     Int?
  paymentMethodCode   String
  paymentMethodName   String
  amount              Float
  transactionCode     String?
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  commissionPayment   CommissionPayment   @relation(fields: [commissionPaymentId], references: [id], onDelete: Cascade)

  @@index([commissionPaymentId])
  @@map("commission_payment_breakdown")
}

model SystemLog {
  id             Int          @id @default(autoincrement())
  organizationId Int
  userId         Int
  action         LogAction
  module         LogModule
  description    String
  entityType     String?
  entityId       Int?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([module, action])
  @@index([organizationId, module])
  @@map("system_logs")
}

model Ticket {
  id             Int              @id @default(autoincrement())
  organizationId Int
  userId         Int
  title          String
  description    String
  priority       TicketPriority   @default(MEDIUM)
  status         TicketStatus     @default(OPEN)
  category       TicketCategory   @default(OTHER)
  assignedToId   Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  resolvedAt     DateTime?
  responses      TicketResponse[]
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([userId])
  @@index([status])
  @@index([priority])
  @@map("tickets")
}

model TicketResponse {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  userId    Int
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_responses")
}

model Notification {
  id             Int              @id @default(autoincrement())
  organizationId Int
  userId         Int?
  type           NotificationType @default(INFO)
  title          String
  message        String
  link           String?
  icon           String?
  isRead         Boolean          @default(false)
  readAt         DateTime?
  data           Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Department {
  id             Int            @id @default(autoincrement())
  organizationId Int
  name           String
  description    String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id])
  storeProducts  StoreProduct[]
  requisitions   Requisition[]

  @@map("departments")
}

model StoreCategory {
  id             Int            @id @default(autoincrement())
  organizationId Int
  name           String
  description    String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id])
  storeProducts  StoreProduct[]

  @@map("store_categories")
}

model StoreProduct {
  id                Int                 @id @default(autoincrement())
  organizationId    Int
  productName       String
  sku               String?
  description       String?
  storeCategoryId   Int
  departmentId      Int
  unitOfMeasurement String
  buyingPrice       Float
  quantity          Int                 @default(0)
  reorderLevel      Int                 @default(0)
  maxStock          Int?
  location          String?
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  organization      Organization        @relation(fields: [organizationId], references: [id])
  storeCategory     StoreCategory       @relation(fields: [storeCategoryId], references: [id])
  department        Department          @relation(fields: [departmentId], references: [id])
  purchaseItems     StorePurchaseItem[]
  requisitionItems  RequisitionItem[]

  @@map("store_products")
}

model StorePurchase {
  id              Int                 @id @default(autoincrement())
  organizationId  Int
  purchaseNumber  String
  supplierId      Int?
  totalAmount     Float               @default(0)
  status          PurchaseStatus      @default(PENDING)
  notes           String?
  deliveryDate    DateTime?
  receivedBy      String?
  createdBy       Int?
  approvedBy      Int?
  approvedAt      DateTime?
  rejectedBy      Int?
  rejectedAt      DateTime?
  rejectionReason String?
  receivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  organization    Organization        @relation(fields: [organizationId], references: [id])
  supplier        Supplier?           @relation(fields: [supplierId], references: [id])
  creator         User?               @relation("PurchaseCreator", fields: [createdBy], references: [id])
  approver        User?               @relation("PurchaseApprover", fields: [approvedBy], references: [id])
  rejector        User?               @relation("PurchaseRejector", fields: [rejectedBy], references: [id])
  items           StorePurchaseItem[]
  receives        StorePurchaseReceive[]

  @@unique([organizationId, purchaseNumber])
  @@map("store_purchases")
}

model StorePurchaseItem {
  id               Int                        @id @default(autoincrement())
  storePurchaseId  Int
  storeProductId   Int
  quantity         Int
  receivedQuantity Int                        @default(0)
  unitPrice        Float
  totalPrice       Float
  createdAt        DateTime                   @default(now())
  storePurchase    StorePurchase              @relation(fields: [storePurchaseId], references: [id], onDelete: Cascade)
  storeProduct     StoreProduct               @relation(fields: [storeProductId], references: [id])
  receiveItems     StorePurchaseReceiveItem[]

  @@map("store_purchase_items")
}

model StorePurchaseReceive {
  id              Int                        @id @default(autoincrement())
  storePurchaseId Int
  grnNumber       String
  receivedById    Int?
  notes           String?
  receivedAt      DateTime                   @default(now())
  createdAt       DateTime                   @default(now())
  storePurchase   StorePurchase              @relation(fields: [storePurchaseId], references: [id], onDelete: Cascade)
  receivedBy      User?                      @relation("PurchaseReceiver", fields: [receivedById], references: [id])
  items           StorePurchaseReceiveItem[]

  @@map("store_purchase_receives")
}

model StorePurchaseReceiveItem {
  id                     Int                   @id @default(autoincrement())
  storePurchaseReceiveId Int
  storePurchaseItemId    Int
  receivedQuantity       Int
  createdAt              DateTime              @default(now())
  storePurchaseReceive   StorePurchaseReceive  @relation(fields: [storePurchaseReceiveId], references: [id], onDelete: Cascade)
  storePurchaseItem      StorePurchaseItem     @relation(fields: [storePurchaseItemId], references: [id])

  @@map("store_purchase_receive_items")
}

model Requisition {
  id                Int                 @id @default(autoincrement())
  organizationId    Int
  requisitionNumber String
  departmentId      Int?
  priority          RequisitionPriority @default(MEDIUM)
  status            RequisitionStatus   @default(PENDING)
  purpose           String?
  notes             String?
  requestedBy       Int
  approvedBy        Int?
  approvedAt        DateTime?
  rejectedBy        Int?
  rejectedAt        DateTime?
  rejectionReason   String?
  issuedBy          Int?
  issuedAt          DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  organization      Organization        @relation(fields: [organizationId], references: [id])
  department        Department?         @relation(fields: [departmentId], references: [id])
  requester         User                @relation("RequisitionRequester", fields: [requestedBy], references: [id])
  approver          User?               @relation("RequisitionApprover", fields: [approvedBy], references: [id])
  rejector          User?               @relation("RequisitionRejector", fields: [rejectedBy], references: [id])
  issuer            User?               @relation("RequisitionIssuer", fields: [issuedBy], references: [id])
  items             RequisitionItem[]

  @@unique([organizationId, requisitionNumber])
  @@map("requisitions")
}

model RequisitionItem {
  id                Int          @id @default(autoincrement())
  requisitionId     Int
  storeProductId    Int
  quantityRequested Int
  quantityApproved  Int?
  quantityIssued    Int?
  notes             String?
  createdAt         DateTime     @default(now())
  requisition       Requisition  @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  storeProduct      StoreProduct @relation(fields: [storeProductId], references: [id])

  @@map("requisition_items")
}

